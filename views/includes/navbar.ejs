<style>

.navbar {
    height: 4rem !important; /* Adjust this value for your desired height */
    margin-bottom: 2rem;
    background-color: #ddbc89;
    opacity:0.9; /* Add margin to the bottom of the navbar */
  }

  .search-btn{
    background-color: #311d06d3;
    color:#dec4a8d3;
    border-radius: 25px;
    padding: 0 1rem 0 1rem;
  }
  .search-btn:hover{
    
    color:#060000;
  }

  .search-btn i {
    display: inline;
    margin-right: 0.5rem;
  }

  .search-inp {
    border-radius: 25px;
  }

  .navbar .nav-link {
      color: black !important;
      transition: transform 0.3s ease, font-size 0.3s ease;
  }

  .navbar .nav-link:hover {
      transform: scale(1.2); /* Makes the link bigger */
      font-size: 1rem; /* Optional: Adjust font size on hover */
  }


</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
          <a class="nav-link" href="/listings">Explore</a>
          </div>
          <div class="navbar-nav ms-auto">
            <form class="d-flex" role="search">
              <input class="form-control me-2 search-inp" type="search" placeholder="Search">
              <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
            </form>
          </div>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/listings/new">List Your Home for Rent</a>
          <% if(!currUser) {%>
          <a class="nav-link" href="/signup"><b>Sign Up</b></a>
          <a class="nav-link" href="/login"><b>Log In</b></a>
          <%}%> <% if(currUser) { %>
            <a class="nav-link" href="/logout">Log Out</a>
            <%}%>
          
        </div>
      </div>
    </div>
  </nav>