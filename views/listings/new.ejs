<% layout("/layouts/boilerplate") %>
<style>
    
    body {
    font-family: "Plus Jakarta Sans", sans-serif;
    background-image: url('/images/background.jpeg');  /* Set your image here */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: rgb(19, 14, 14);
    height: 100vh;  /* Ensure it covers the entire height of the viewport */
    margin: 0;
    background-attachment: fixed
    }

    body::before {
  /* Add a dark, transparent overlay on top of the image */
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7); /* Dark black with 50% opacity */
  z-index: -1; /* Ensure the overlay is below text but above the image */
  filter: blur(8px); /* Apply blur to the background image */
}

.add{
    color:antiquewhite;
}

.form-label{
    color:antiquewhite
}


.btn-grayish:hover {
    background-color: #5a6268; /* Slightly darker gray on hover */
  }
</style>

<body>
    <div class="row mt-3">
    <div class="col-8 offset-2">
    <h1 class="add">List Your Home For Rent !</h1>
    <br/>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <div class="mb-3">
                <label for="propertyType" class="form-label">Property Type</label>
                <select name="listing[propertyType]" id="propertyType" class="form-control" required>
                    <option value="" disabled selected>Select Property Type</option>
                    <option value="Room">Room</option>
                    <option value="Flat">Flat</option>
                    <option value="Flat">Apartment</option>
                </select>
                <div class="invalid-feedback">Select Property Type !</div>
            </div>
            
        </div>
        
        <div class="mb-3">
            <label for="numBHK" class="form-label">Enter BHK</label>
            <input name="listing[numBHK]" id="numBHK" type="number" min="1" class="form-control" placeholder="Enter number of BHK" required>
            <div class="invalid-feedback">Please enter BHK!</div>
        </div>
     
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" required></textarea>
            <div class="invalid-feedback">Please enter a short description!</div>
        </div>
        <!-- Separate blocks for each image -->
        <div class="mb-3">
            <label for="image1" class="form-label edit">Upload Image 1</label>
            <input 
              name="listing[images]" 
              id="image1" 
              type="file" 
              class="form-control" 
              accept="image/*"
              required 
            />
            <div class="invalid-feedback">Please upload Image 1.</div>
          </div>
  
          <div class="mb-3">
            <label for="image2" class="form-label edit">Upload Image 2</label>
            <input 
              name="listing[images]" 
              id="image2" 
              type="file" 
              class="form-control" 
              accept="image/*" 
            />
            <div class="invalid-feedback">Please upload Image 2.</div>
          </div>
  
          <div class="mb-3">
            <label for="image3" class="form-label edit">Upload Image 3</label>
            <input 
              name="listing[images]" 
              id="image3" 
              type="file" 
              class="form-control" 
              accept="image/*" 
            />
            <div class="invalid-feedback">Please upload Image 3.</div>
          </div>
          <!-- End of separate image blocks -->
        
        <div class="row">
            <div class="mb-3 col-4">
                <label for="price" class="form-label">Price</label>
                <input name="listing[price]" placeholder="Enter price" class="form-control" required/>
                <div class="invalid-feedback">Enter Price</div>
            </div>
            <div class="mb-3 col-md-8">
                <label for="country" class="form-label">Country</label>
                <input name="listing[country]" placeholder="Enter country" type="text" class="form-control" required/>
                <div class="invalid-feedback">Enter a Country name</div>
            </div>
        </div>
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" placeholder="Enter location" type="text" class="form-control" required/>
            <div class="invalid-feedback">Enter Location</div>
        </div>
        <button class="btn btn-secondary" style="color: black;">Add</button>
        </form>
    </div>
</div>
</body>